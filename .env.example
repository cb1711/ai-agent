# ── LLM Provider ─────────────────────────────────────────
# "claude" (default) or "ollama"
LLM_PROVIDER=claude

# ── Anthropic / Claude ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Ollama ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=987654321

# ── Email (SMTP) ──────────────────────────────────────────
# Gmail: use an App Password (not your account password)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com

# ── Database paths (relative to working directory) ────────
MEMORY_DB_PATH=agent_memory.db
SCHEDULER_DB_PATH=agent_scheduler.db

# ── Agent behaviour ───────────────────────────────────────
# Change SESSION_ID to start a fresh conversation history
SESSION_ID=default
MAX_HISTORY_TURNS=20
